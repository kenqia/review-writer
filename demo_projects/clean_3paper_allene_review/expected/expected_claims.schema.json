{
  "description": "Draft schema for future human-verified key claims. This is a TODO schema, not extracted claims.",
  "type": "object",
  "required": ["paper_id", "claims", "human_verified", "verification_status", "needs_human_review"],
  "properties": {
    "paper_id": {
      "type": "string"
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_id", "claim_text", "evidence_location", "needs_human_check"],
        "properties": {
          "claim_id": {"type": "string"},
          "claim_text": {"type": "string"},
          "evidence_location": {"type": "string"},
          "needs_human_check": {"type": "boolean"}
        }
      }
    },
    "human_verified": {
      "const": false
    },
    "verification_status": {
      "enum": ["todo", "verified_draft", "needs_human_review"]
    },
    "needs_human_review": {
      "const": true
    },
    "pdf_read_scope": {
      "enum": ["filename_metadata_or_first_page_only", "limited_readonly"]
    }
  }
}
