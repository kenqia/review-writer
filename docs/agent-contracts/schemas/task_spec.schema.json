{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TASK_SPEC",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "objective", "background", "frozen_decisions", "allowed_paths", "forbidden_paths", "inputs", "required_outputs", "acceptance_criteria", "verification_commands", "safety_boundaries", "network_policy", "model_policy", "stop_conditions", "human_checkpoint"],
  "properties": {
    "task_id": {"type": "string", "pattern": "^[A-Z][A-Z0-9-]+$"},
    "objective": {"type": "string", "minLength": 1}, "background": {"type": "string", "minLength": 1},
    "frozen_decisions": {"$ref": "#/$defs/string_list"}, "allowed_paths": {"$ref": "#/$defs/path_list"},
    "forbidden_paths": {"$ref": "#/$defs/path_list"}, "inputs": {"$ref": "#/$defs/string_list"},
    "required_outputs": {"$ref": "#/$defs/string_list"}, "acceptance_criteria": {"$ref": "#/$defs/string_list"},
    "verification_commands": {"$ref": "#/$defs/string_list"}, "safety_boundaries": {"$ref": "#/$defs/string_list"},
    "network_policy": {"type": "string", "minLength": 1}, "model_policy": {"type": "string", "minLength": 1},
    "stop_conditions": {"$ref": "#/$defs/string_list"}, "human_checkpoint": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "string_list": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "path_list": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._+@=:/ -]+$"}}
  }
}
