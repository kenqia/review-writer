# Copy to .env locally if needed. Do not commit real values.
# Keep real keys out of this repository and out of shell rc files.
# Real provider calls must be explicitly approved for a single run.
# Offline smoke checks must pass when all key variables are empty.

REVIEW_WRITER_ROOT=/path/to/review-writer
REVIEW_WRITER_DATA_ROOT=/path/to/review-writer-data

# Optional LLM providers. Leave blank in committed examples.
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
LOCAL_LLM_BASE_URL=http://127.0.0.1:8000/v1
ALIBABA_WORKSPACE_ID=
ALIBABA_REGION=cn-beijing

# Optional paper retrieval providers. Do not upload papers without approval.
SCIATLAS_API_BASE_URL=http://sciatlas.openkg.cn
SCIATLAS_API_KEY=
ALIBABA_BAILIAN_KB_ID=
BAILIAN_KNOWLEDGE_BASE_ID=

# Optional image providers. Disabled by default.
ALIBABA_IMAGE_API_KEY=
WANX_API_KEY=
QWEN_IMAGE_API_KEY=

# Optional MinerU parsing
MINERU_API_TOKEN=
