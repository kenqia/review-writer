{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:review-writer:phase8:v3.1:source-unit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_unit_id", "unit_kind", "paper_id", "source_document_ids",
    "source_roles", "source_artifacts", "source_page_counts",
    "printed_page_labels", "search_scope", "review_question",
    "included_claim_classes", "excluded_material",
    "required_sections_or_page_ranges", "completion_criteria", "task_hash"
  ],
  "properties": {
    "source_unit_id": {"type": "string", "pattern": "^SU-[0-9a-f]{16}$"},
    "unit_kind": {"enum": ["SCIENTIFIC", "CALIBRATION"]},
    "paper_id": {"enum": ["F3I", "F47A", "P403"]},
    "source_document_ids": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"enum": ["F3I_MAIN", "F47A_MAIN", "F47A_SI", "P403_MAIN", "P403_SI"]}
    },
    "source_roles": {"type": "object", "minProperties": 1, "additionalProperties": {"enum": ["MAIN", "SI"]}},
    "source_artifacts": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "string", "pattern": "^sources/[A-Za-z0-9_.-]+\\.pdf$"}},
    "source_page_counts": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "integer", "minimum": 1}},
    "printed_page_labels": {
      "type": "object", "minProperties": 1,
      "additionalProperties": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "string", "minLength": 1}}
    },
    "search_scope": {"enum": ["EXACT_PAGE", "PAGE_WINDOW", "SECTION", "FULL_SOURCE"]},
    "review_question": {"type": "string", "minLength": 40},
    "included_claim_classes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "excluded_material": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "required_sections_or_page_ranges": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["source_document_id", "start_page_index", "end_page_index", "page_indices"],
        "properties": {
          "source_document_id": {"type": "string"},
          "start_page_index": {"type": "integer", "minimum": 0},
          "end_page_index": {"type": "integer", "minimum": 0},
          "page_indices": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "integer", "minimum": 0}}
        }
      }
    },
    "completion_criteria": {
      "type": "object", "additionalProperties": false,
      "required": ["required_page_indices", "completed_requires_all_required_pages", "completed_minimum_claim_count", "completed_maximum_claim_count", "zero_claim_statuses", "out_of_scope_allowed", "completion_basis"],
      "properties": {
        "required_page_indices": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["source_document_id", "page_indices"],
            "properties": {
              "source_document_id": {"type": "string"},
              "page_indices": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "integer", "minimum": 0}}
            }
          }
        },
        "completed_requires_all_required_pages": {"const": true},
        "completed_minimum_claim_count": {"type": "integer", "minimum": 1},
        "completed_maximum_claim_count": {"type": ["integer", "null"], "minimum": 1},
        "zero_claim_statuses": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["NO_QUALIFYING_EVIDENCE", "SOURCE_UNREADABLE", "OUT_OF_SCOPE"]}},
        "out_of_scope_allowed": {"type": "boolean"},
        "completion_basis": {"type": "string", "minLength": 20}
      }
    },
    "task_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
