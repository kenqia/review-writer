{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:review-writer:project-manifest:1.0",
  "title": "Review Writer M0 ProjectManifest",
  "description": "Editable case-neutral project configuration for the M0-PR-A acceptance paths.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_schema_version",
    "project_id",
    "project_title",
    "initial_user_intent",
    "discovery_policy",
    "output_language",
    "citation_style",
    "paths",
    "initial_source_inputs",
    "network_policy"
  ],
  "x-runtime-invariants": [
    "PROJECT_ID_LOCKED_AFTER_PROJECT_RECORDS",
    "SOURCE_ID_UNIQUE",
    "NORMALIZED_SOURCE_PATH_UNIQUE_CROSS_PLATFORM",
    "EXACTLY_ONE_MAIN_PER_PAPER",
    "SI_REQUIRES_MAIN",
    "SOURCE_PATH_MUST_BE_REGULAR_FILE",
    "SOURCE_PATH_MUST_RESOLVE_WITHIN_SEED_ROOT",
    "SOURCE_CONTENT_HASH_CAPTURED_IN_SNAPSHOT",
    "SOURCE_CONTENT_HASH_REVERIFIED_ON_CONSUME",
    "ADAPTER_REF_CLOSED_ALLOWLIST"
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "portableRelativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!\\\\)(?!.*\\\\)(?!\\.\\.(?:/|$))(?!.*(?:/)\\.\\.(?:/|$))(?!\\.(?:/|$))(?!.*(?:/)\\.(?:/|$))(?!.*//)(?!.*\\/$)[^\\u0000]+$",
      "$comment": "Runtime validation also resolves symlink and reparse targets and rejects any target outside the permitted root."
    },
    "sourceInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "paper_id",
        "relative_path",
        "document_role",
        "usage_role"
      ],
      "properties": {
        "source_id": {
          "$ref": "#/$defs/identifier"
        },
        "paper_id": {
          "$ref": "#/$defs/identifier"
        },
        "relative_path": {
          "$ref": "#/$defs/portableRelativePath"
        },
        "document_role": {
          "enum": [
            "MAIN",
            "SI"
          ]
        },
        "usage_role": {
          "enum": [
            "EVIDENCE",
            "BACKGROUND",
            "DISCOVERY_ONLY"
          ]
        }
      }
    }
  },
  "properties": {
    "manifest_schema_version": {
      "const": "project-manifest-1.0"
    },
    "project_id": {
      "$ref": "#/$defs/identifier"
    },
    "project_title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "initial_user_intent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "goal",
        "scope"
      ],
      "properties": {
        "goal": {
          "type": "string",
          "minLength": 1,
          "$comment": "The shared resolved-config resolver enforces 1-4000 Unicode code points after line-ending, NFC, and outer-whitespace normalization."
        },
        "scope": {
          "type": "string",
          "minLength": 1,
          "$comment": "The shared resolved-config resolver enforces 1-8000 Unicode code points after line-ending, NFC, and outer-whitespace normalization."
        }
      }
    },
    "discovery_policy": {
      "const": "CLOSED_CORPUS"
    },
    "output_language": {
      "type": "string",
      "minLength": 1,
      "maxLength": 35
    },
    "citation_style": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "seed_source_root",
        "project_data_root",
        "export_root"
      ],
      "properties": {
        "seed_source_root": {
          "$ref": "#/$defs/portableRelativePath"
        },
        "project_data_root": {
          "$ref": "#/$defs/portableRelativePath"
        },
        "export_root": {
          "$ref": "#/$defs/portableRelativePath"
        }
      }
    },
    "initial_source_inputs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/sourceInput"
      },
      "$comment": "Runtime validation enforces unique source_id, cross-platform normalized path uniqueness, exactly one MAIN per paper_id, and SI-to-MAIN association."
    },
    "network_policy": {
      "const": "OFFLINE_ONLY"
    },
    "adapter_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
      "$comment": "Runtime validation accepts only a closed product-maintained adapter allowlist; paths, imports, commands, URLs, and plugin entrypoints are forbidden."
    }
  }
}
